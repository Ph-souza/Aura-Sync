<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Splash" parent="Theme.SplashScreen">
        <!-- Fundo transparente para combinar com a tela que virá ou cor principal -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo</item>
        <!-- Tema que será aplicado depois da splash screen inicial -->
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar" />
</resources>
